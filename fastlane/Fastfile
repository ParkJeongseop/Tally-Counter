default_platform(:ios)

platform :ios do
  desc "Take localized screenshots"
  lane :screenshots do
    capture_ios_screenshots(
      workspace: "ios/TallyCounter.xcworkspace",
      scheme: "TallyCounterUITests",
      devices: [
        "iPhone 16 Pro Max",
        "iPhone 16 Plus",
        "iPad Pro 13-inch (M4)",
      ],
      languages: [
        "en-US",
        "ko",
        "ja",
        "zh-Hans",
        "es-ES",
        "fr-FR",
        "de-DE",
        "pt-PT",
      ],
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true,
      override_status_bar: true,
      localize_simulator: true,
      concurrent_simulators: true,
    )
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    deliver(
      app_identifier: "com.parkjeongseop.tallycounter",
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      screenshots_path: "./fastlane/screenshots",
    )
  end

  desc "Take screenshots and upload to App Store Connect"
  lane :screenshots_and_upload do
    screenshots
    upload_screenshots
  end
end

platform :android do
  desc "Take localized screenshots"
  lane :screenshots do
    capture_android_screenshots(
      app_package_name: "com.parkjeongseop.tallycounter",
      app_apk_path: "android/app/build/outputs/apk/debug/app-debug.apk",
      tests_apk_path: "android/app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk",
      locales: [
        "en-US",
        "ko-KR",
        "ja-JP",
        "zh-CN",
        "es-ES",
        "fr-FR",
        "de-DE",
        "pt-PT",
      ],
      output_directory: "./fastlane/screenshots_android",
      clear_previous_screenshots: true,
      use_timestamp_suffix: false,
      ending_locale: "en-US",
    )
  end

  desc "Upload screenshots to Google Play"
  lane :upload_screenshots do
    upload_to_play_store(
      package_name: "com.parkjeongseop.tallycounter",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      screenshots_path: "./fastlane/screenshots_android",
    )
  end
end
